{
	"compilerOptions": {
		"strict": true,
		"target": "es2025",
		"module": "nodenext",
		"moduleResolution": "nodenext",

		"rootDir": "./src",
		"outDir": "./target",
		"paths": {
			"discord.js": ["../node_modules/discord.js"]
		},

		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true
	}
}
